generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ActorRole {
  RESEARCHER
  SENIOR_VERIFIER
  ADMINISTRATOR
  COMMERCIAL_OPERATOR
}

enum OrganizationType {
  BRAND
  ISSUER
  NETWORK
  PROGRAM_MANAGER
}

enum Lifecycle {
  LIVE
  WAITLIST
  PAUSED
  SUNSET
}

enum ValueState {
  KNOWN
  NOT_OFFERED
  NOT_DISCLOSED
  NOT_APPLICABLE
  CONFLICTING
  STALE
}

enum ClaimField {
  ELIGIBILITY
  CARD_TYPE
  NETWORK
  FUNDING_MODEL
  SUPPORTED_ASSETS
  KYC
  ISSUANCE_FEE
  SHIPPING_FEE
  MONTHLY_FEE
  ANNUAL_FEE
  TOP_UP_FEE
  CONVERSION_FEE
  FX_FEE
  ATM_FEE
  ATM_LIMIT
  REWARD_RATE
  REWARD_CAP
  REWARD_CURRENCY
  REWARD_QUALIFICATION
  MOBILE_WALLET
  BENEFIT
  PROMOTION
  SPEND_LIMIT
}

enum PlanDimensionKind {
  CARD_PLAN
  SUBSCRIPTION
  MEMBERSHIP_LEVEL
  REWARD_TIER
  REWARD_CATEGORY
  REWARD_OFFER
  LOYALTY_TIER
  LOYALTY_LEVEL
  LOYALTY_RANK
  VERIFICATION_LEVEL
  ACCOUNT_TIER
  CARD_MODE
}

enum PlanResearchStatus {
  STRUCTURED
  PARTIAL
  NO_PUBLIC_MATRIX
  BLOCKED
}

enum ClaimStatus {
  CANDIDATE
  IN_REVIEW
  APPROVED
  PUBLISHED
  REJECTED
}

enum ReviewAction {
  SUBMITTED
  APPROVED
  REJECTED
  PUBLISHED
}

enum AuthorityTier {
  A
  B
  C
  D
}

enum EvidenceRelation {
  SUPPORTS
  CONTRADICTS
}

enum ImportRunStatus {
  RUNNING
  SUCCEEDED
  FAILED
  QUARANTINED
}

enum CandidateStatus {
  DISCOVERED
  TRIAGED
  VERIFYING
  PROMOTED
  REJECTED
}

model Actor {
  id                 String                @id @default(uuid()) @db.Uuid
  email              String                @unique
  displayName        String
  role               ActorRole
  createdAt          DateTime              @default(now()) @db.Timestamptz(3)
  claimsCreated      Claim[]               @relation("ClaimCreator")
  claimsApproved     Claim[]               @relation("ClaimApprover")
  reviews            ReviewEvent[]
  publicationRecords PublicationRevision[]
}

model Organization {
  id               String           @id @default(uuid()) @db.Uuid
  slug             String           @unique
  name             String
  type             OrganizationType
  jurisdictionCode String?          @db.VarChar(2)
  createdAt        DateTime         @default(now()) @db.Timestamptz(3)
  programs         CardProgram[]    @relation("ProgramOwner")
  issuedOfferings  CardOffering[]   @relation("OfferingIssuer")
}

model CardProgram {
  id                  String         @id @default(uuid()) @db.Uuid
  slug                String         @unique
  name                String
  ownerOrganizationId String         @db.Uuid
  ownerOrganization   Organization   @relation("ProgramOwner", fields: [ownerOrganizationId], references: [id])
  createdAt           DateTime       @default(now()) @db.Timestamptz(3)
  offerings           CardOffering[]
}

model CardOffering {
  id              String           @id @default(uuid()) @db.Uuid
  slug            String           @unique
  programId       String           @db.Uuid
  issuerId        String           @db.Uuid
  label           String
  countryCode     String           @db.VarChar(2)
  lifecycle       Lifecycle
  cardType        String
  fundingModel    String
  settlementModel String
  baseCurrency    String           @db.VarChar(3)
  network         String
  validFrom       DateTime         @db.Date
  validTo         DateTime?        @db.Date
  createdAt       DateTime         @default(now()) @db.Timestamptz(3)
  program         CardProgram      @relation(fields: [programId], references: [id], onDelete: Restrict)
  issuer          Organization     @relation("OfferingIssuer", fields: [issuerId], references: [id], onDelete: Restrict)
  plans           Plan[]
  planDimensions  PlanDimension[]
  claims          Claim[]
  publishedClaims PublishedClaim[]

  @@index([countryCode, lifecycle])
}

model PlanDimension {
  id           String            @id @default(uuid()) @db.Uuid
  offeringId   String            @db.Uuid
  slug         String
  label        String
  kind         PlanDimensionKind
  combinable   Boolean           @default(false)
  displayOrder Int
  createdAt    DateTime          @default(now()) @db.Timestamptz(3)
  offering     CardOffering      @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  plans        Plan[]

  @@unique([offeringId, slug])
  @@unique([id, offeringId])
  @@unique([offeringId, displayOrder])
}

model Plan {
  id              String                    @id @default(uuid()) @db.Uuid
  slug            String                    @unique
  offeringId      String                    @db.Uuid
  dimensionId     String                    @db.Uuid
  name            String
  tierOrder       Int
  qualification   String
  lifecycle       Lifecycle
  offering        CardOffering              @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  dimension       PlanDimension             @relation(fields: [dimensionId, offeringId], references: [id, offeringId], onDelete: Cascade)
  claims          Claim[]
  publishedClaims PublishedClaim[]
  claimScopes     ClaimPlanScope[]
  publishedScopes PublishedClaimPlanScope[]

  @@unique([dimensionId, tierOrder])
  @@unique([id, offeringId])
}

model Source {
  id            String               @id @default(uuid()) @db.Uuid
  slug          String               @unique
  title         String
  url           String
  sourceType    String
  authorityTier AuthorityTier
  rightsStatus  String
  countryCode   String?              @db.VarChar(2)
  artifacts     SourceArtifact[]
  importRuns    SourceImportRun[]
  metricSeries  MarketMetricSeries[]
}

model SourceArtifact {
  id                String                       @id @default(uuid()) @db.Uuid
  sourceId          String                       @db.Uuid
  observedAt        DateTime                     @db.Timestamptz(3)
  contentHash       String                       @unique
  locator           String
  mimeType          String
  rightsStatus      String
  fixturePath       String?
  source            Source                       @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  claimEvidence     ClaimEvidence[]
  candidateEvidence DiscoveryCandidateEvidence[]
  importRuns        SourceImportRun[]
}

model SourceImportRun {
  id               String               @id @default(uuid()) @db.Uuid
  sourceId         String               @db.Uuid
  artifactId       String?              @db.Uuid
  status           ImportRunStatus      @default(RUNNING)
  collector        String
  collectorVersion String
  startedAt        DateTime             @default(now()) @db.Timestamptz(3)
  finishedAt       DateTime?            @db.Timestamptz(3)
  observedCount    Int                  @default(0)
  acceptedCount    Int                  @default(0)
  errorCode        String?
  source           Source               @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  artifact         SourceArtifact?      @relation(fields: [artifactId], references: [id], onDelete: Restrict)
  candidates       DiscoveryCandidate[]

  @@index([sourceId, startedAt])
  @@index([status, startedAt])
}

model DiscoveryCandidate {
  id                 String                       @id @default(uuid()) @db.Uuid
  importRunId        String                       @db.Uuid
  externalKey        String
  canonicalHint      String
  issuerHint         String
  officialUrl        String?
  observation        Json
  status             CandidateStatus              @default(DISCOVERED)
  planResearchStatus PlanResearchStatus            @default(NO_PUBLIC_MATRIX)
  planResearchReason String?
  rightsBasis        String
  discoveredAt       DateTime                     @db.Timestamptz(3)
  reviewedAt         DateTime?                    @db.Timestamptz(3)
  reviewReason       String?
  importRun          SourceImportRun              @relation(fields: [importRunId], references: [id], onDelete: Cascade)
  evidence           DiscoveryCandidateEvidence[]
  planDimensions     CandidatePlanDimension[]

  @@unique([importRunId, externalKey])
  @@index([status, canonicalHint])
}

model CandidatePlanDimension {
  id           String                    @id @default(uuid()) @db.Uuid
  candidateId  String                    @db.Uuid
  slug         String
  label        String
  kind         PlanDimensionKind
  combinable   Boolean                   @default(false)
  displayOrder Int
  observedAt   DateTime                  @db.Timestamptz(3)
  candidate    DiscoveryCandidate        @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  options      CandidatePlanOption[]

  @@unique([candidateId, slug])
  @@unique([candidateId, displayOrder])
}

model CandidatePlanOption {
  id              String                 @id @default(uuid()) @db.Uuid
  dimensionId     String                 @db.Uuid
  slug            String
  name            String
  tierOrder       Int
  qualification   String?
  lifecycle       Lifecycle?
  displayValue    String
  valueJson       Json?
  scopeJson       Json
  sourceFieldKeys String[]
  observedAt      DateTime               @db.Timestamptz(3)
  dimension       CandidatePlanDimension @relation(fields: [dimensionId], references: [id], onDelete: Cascade)

  @@unique([dimensionId, slug])
  @@unique([dimensionId, tierOrder])
}

model DiscoveryCandidateEvidence {
  candidateId  String             @db.Uuid
  artifactId   String             @db.Uuid
  fieldKey     String
  relation     EvidenceRelation   @default(SUPPORTS)
  excerptHash  String
  displayValue String
  valueJson    Json?
  scopeJson    Json
  observedAt   DateTime           @db.Timestamptz(3)
  candidate    DiscoveryCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  artifact     SourceArtifact     @relation(fields: [artifactId], references: [id], onDelete: Restrict)

  @@id([candidateId, artifactId, fieldKey])
  @@index([candidateId, fieldKey])
}

model MarketMetricSeries {
  id                   String              @id @default(uuid()) @db.Uuid
  sourceId             String              @db.Uuid
  slug                 String              @unique
  label                String
  unit                 String
  aggregation          String
  eventDefinition      String
  observationBasis     String
  includesTopups       Boolean
  includesOffchainData Boolean
  coverageJson         Json
  methodVersion        String
  licenseBasis         String
  publicationAllowed   Boolean             @default(false)
  createdAt            DateTime            @default(now()) @db.Timestamptz(3)
  source               Source              @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  points               MarketMetricPoint[]

  @@index([sourceId, publicationAllowed])
}

model MarketMetricPoint {
  id          String             @id @default(uuid()) @db.Uuid
  seriesId    String             @db.Uuid
  periodStart DateTime           @db.Date
  value       Decimal            @db.Decimal(30, 8)
  partial     Boolean            @default(false)
  revision    Int                @default(1)
  observedAt  DateTime           @db.Timestamptz(3)
  metadata    Json?
  series      MarketMetricSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([seriesId, periodStart, revision])
  @@index([seriesId, periodStart])
}

model Claim {
  id             String           @id @default(uuid()) @db.Uuid
  offeringId     String           @db.Uuid
  planId         String?          @db.Uuid
  field          ClaimField
  subjectKey     String           @default("default") @db.VarChar(160)
  scopeKey       String           @default("offering") @db.VarChar(500)
  valueState     ValueState
  displayValue   String
  valueJson      Json?
  countryCode    String           @db.VarChar(2)
  critical       Boolean          @default(true)
  status         ClaimStatus      @default(CANDIDATE)
  effectiveFrom  DateTime         @db.Date
  effectiveTo    DateTime?        @db.Date
  observedAt     DateTime         @db.Timestamptz(3)
  createdById    String           @db.Uuid
  approvedById   String?          @db.Uuid
  publishedAt    DateTime?        @db.Timestamptz(3)
  createdAt      DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime         @updatedAt @db.Timestamptz(3)
  offering       CardOffering     @relation(fields: [offeringId], references: [id], onDelete: Restrict)
  plan           Plan?            @relation(fields: [planId, offeringId], references: [id, offeringId], onDelete: Restrict)
  createdBy      Actor            @relation("ClaimCreator", fields: [createdById], references: [id], onDelete: Restrict)
  approvedBy     Actor?           @relation("ClaimApprover", fields: [approvedById], references: [id], onDelete: Restrict)
  evidence       ClaimEvidence[]
  planScopes     ClaimPlanScope[]
  reviewEvents   ReviewEvent[]
  publishedClaim PublishedClaim?

  @@unique([id, offeringId])
  @@index([offeringId, planId, field, status])
  @@index([countryCode, status, effectiveTo])
}

model ClaimPlanScope {
  claimId    String @db.Uuid
  planId     String @db.Uuid
  offeringId String @db.Uuid
  claim      Claim  @relation(fields: [claimId, offeringId], references: [id, offeringId], onDelete: Cascade)
  plan       Plan   @relation(fields: [planId, offeringId], references: [id, offeringId], onDelete: Restrict)

  @@id([claimId, planId])
  @@index([planId])
}

model ClaimEvidence {
  claimId     String           @db.Uuid
  artifactId  String           @db.Uuid
  relation    EvidenceRelation @default(SUPPORTS)
  excerptHash String
  claim       Claim            @relation(fields: [claimId], references: [id], onDelete: Cascade)
  artifact    SourceArtifact   @relation(fields: [artifactId], references: [id], onDelete: Restrict)

  @@id([claimId, artifactId])
}

model ReviewEvent {
  id        String       @id @default(uuid()) @db.Uuid
  claimId   String       @db.Uuid
  actorId   String       @db.Uuid
  action    ReviewAction
  reason    String
  createdAt DateTime     @default(now()) @db.Timestamptz(3)
  claim     Claim        @relation(fields: [claimId], references: [id], onDelete: Cascade)
  actor     Actor        @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([claimId, createdAt])
}

model PublicationRevision {
  id              String           @id @default(uuid()) @db.Uuid
  version         Int              @unique
  summary         String
  publishedAt     DateTime         @default(now()) @db.Timestamptz(3)
  publishedById   String           @db.Uuid
  publishedBy     Actor            @relation(fields: [publishedById], references: [id], onDelete: Restrict)
  publishedClaims PublishedClaim[]
}

model PublishedClaim {
  id                    String                    @id @default(uuid()) @db.Uuid
  claimId               String                    @unique @db.Uuid
  offeringId            String                    @db.Uuid
  planId                String?                   @db.Uuid
  field                 ClaimField
  subjectKey            String                    @default("default") @db.VarChar(160)
  scopeKey              String                    @default("offering") @db.VarChar(500)
  valueState            ValueState
  displayValue          String
  valueJson             Json?
  countryCode           String                    @db.VarChar(2)
  effectiveFrom         DateTime                  @db.Date
  effectiveTo           DateTime?                 @db.Date
  observedAt            DateTime                  @db.Timestamptz(3)
  publishedAt           DateTime                  @db.Timestamptz(3)
  publicationRevisionId String                    @db.Uuid
  claim                 Claim                     @relation(fields: [claimId], references: [id], onDelete: Restrict)
  offering              CardOffering              @relation(fields: [offeringId], references: [id], onDelete: Restrict)
  plan                  Plan?                     @relation(fields: [planId, offeringId], references: [id, offeringId], onDelete: Restrict)
  publicationRevision   PublicationRevision       @relation(fields: [publicationRevisionId], references: [id], onDelete: Restrict)
  planScopes            PublishedClaimPlanScope[]

  @@unique([id, offeringId])
  @@index([offeringId, planId, field])
  @@index([countryCode, field])
}

model PublishedClaimPlanScope {
  publishedClaimId String         @db.Uuid
  planId           String         @db.Uuid
  offeringId       String         @db.Uuid
  publishedClaim   PublishedClaim @relation(fields: [publishedClaimId, offeringId], references: [id, offeringId], onDelete: Cascade)
  plan             Plan           @relation(fields: [planId, offeringId], references: [id, offeringId], onDelete: Restrict)

  @@id([publishedClaimId, planId])
  @@index([planId])
}
